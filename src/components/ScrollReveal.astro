---
interface Props {
  delay?: number;
  duration?: number;
  distance?: string;
  triggerOnce?: boolean;
  class?: string;
}

const {
  delay = 0,
  duration = 850,
  distance = "32px",
  triggerOnce = true,
  class: className = ""
} = Astro.props;
---

<div
  class:list={["scroll-reveal", className]}
  data-scroll-reveal
  data-trigger-once={triggerOnce}
  style={`--reveal-delay:${delay}ms;--reveal-duration:${duration}ms;--reveal-distance:${distance};`}
>
  <slot />
</div>
