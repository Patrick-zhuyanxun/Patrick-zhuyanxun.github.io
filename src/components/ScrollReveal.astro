---
interface Props {
  delay?: number;
  duration?: number;
  distance?: string;
  triggerOnce?: boolean;
  class?: string;
}

const {
  delay = 0,
  duration = 850,
  distance = "32px",
  triggerOnce = true,
  class: className = ""
} = Astro.props;
---

<div
  class:list={["scroll-reveal", className]}
  data-scroll-reveal
  data-trigger-once={triggerOnce}
  style={`--reveal-delay:${delay}ms;--reveal-duration:${duration}ms;--reveal-distance:${distance};`}
>
  <slot />
</div>

<script>
  const revealTargets = document.querySelectorAll<HTMLElement>("[data-scroll-reveal]:not([data-reveal-ready])");
  const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  if (reduceMotion || !("IntersectionObserver" in window)) {
    revealTargets.forEach((target) => target.classList.add("is-visible"));
  } else {
    const revealObserver = new IntersectionObserver((entries, observer) => {
      entries.forEach((entry) => {
        const target = entry.target as HTMLElement;
        if (entry.isIntersecting) {
          target.classList.add("is-visible");
          if (target.dataset.triggerOnce !== "false") observer.unobserve(target);
        } else if (target.dataset.triggerOnce === "false") {
          target.classList.remove("is-visible");
        }
      });
    }, { rootMargin: "0px 0px -12% 0px", threshold: 0.12 });

    revealTargets.forEach((target) => {
      target.dataset.revealReady = "true";
      revealObserver.observe(target);
    });
  }
</script>
