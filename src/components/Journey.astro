---
import { journey } from "../data/site";

interface Props {
  limit?: number;
  showLink?: boolean;
}

const { limit, showLink = false } = Astro.props;
const entries = typeof limit === "number" ? journey.slice(0, limit) : journey;
---

<section class="section journey-section" id="journey">
  <div class="wrap">
    <div class="section-head journey-head">
      <p class="section-index">04</p>
      <div>
        <p class="section-label"><span data-zh>走過的路</span><span data-en>Along the way</span></p>
        <h2><span data-zh>學習、實作與工作的交會。</span><span data-en>Where learning, building and work meet.</span></h2>
      </div>
    </div>
    <div class="timeline">
      {entries.map((item) => (
        <details class:list={["timeline-entry", item.type]}>
          <summary>
            <span class="timeline-date"><span data-zh>{item.dateZh}</span><span data-en>{item.dateEn}</span></span>
            <span class="timeline-marker" aria-hidden="true"></span>
            <span class="timeline-summary"><span class="timeline-type"><span data-zh>{item.typeZh}</span><span data-en>{item.typeEn}</span></span><strong><span data-zh>{item.titleZh}</span><span data-en>{item.titleEn}</span></strong></span>
          </summary>
          <p><span data-zh>{item.descriptionZh}</span><span data-en>{item.descriptionEn}</span></p>
        </details>
      ))}
    </div>
    {showLink && (
      <a class="text-link journey-link" href="/experience/">
        <span data-zh>查看完整經歷</span><span data-en>View the complete journey</span>
        <span aria-hidden="true">↗</span>
      </a>
    )}
  </div>
</section>
