---
interface Props {
  delay?: number;
  duration?: number;
  distance?: string;
  triggerOnce?: boolean;
  class?: string;
}

const {
  delay = 0,
  duration = 900,
  distance = "110%",
  triggerOnce = true,
  class: className = ""
} = Astro.props;
---

<span
  class:list={["reveal-mask", className]}
  data-text-reveal
  data-trigger-once={triggerOnce}
  style={`--text-delay:${delay}ms;--text-duration:${duration}ms;--text-distance:${distance};`}
>
  <span class="reveal-content"><slot /></span>
</span>
