---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import SocialLinks from "../components/SocialLinks.astro";
import TextReveal from "../components/TextReveal.astro";
import { profile } from "../data/site";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
const templatePosts = [
  { index: "01", category: "ROBOTICS", titleZh: "機器人如何從感知走到動作", titleEn: "How robots move from perception to action", tone: "lime" },
  { index: "02", category: "AI TOOLS", titleZh: "我如何整理與使用 AI 工具", titleEn: "How I organize and use AI tools", tone: "blue" },
  { index: "03", category: "READING", titleZh: "近期閱讀與生活觀察", titleEn: "Recent reading and observations", tone: "coral" },
  { index: "04", category: "RECAP", titleZh: "月度回顧：留下值得記住的事", titleEn: "Monthly recap: what was worth keeping", tone: "white" }
];
---

<Base
  title={`${profile.name} ${profile.englishName} | 文章與觀點`}
  description="朱彥勳的公開文章與觀點，整理機器人、AI、閱讀、影片與生活觀察。"
  bodyClass="home-cinematic blog-home"
  themeColor="#090a0b"
>
  <main id="main-content" class="blog-home-main">
    <section class="blog-hero" aria-labelledby="blog-home-title">
      <div class="cinematic-wrap blog-hero-layout">
        <div class="blog-hero-copy">
          <p class="cinematic-overline">
            <TextReveal><span data-zh>朱彥勳的公開筆記</span><span data-en>PATRICK ZHU'S PUBLIC NOTES</span></TextReveal>
          </p>
          <h1 id="blog-home-title" aria-label="Read. Think.">
            <TextReveal delay={90}>READ.</TextReveal>
            <TextReveal delay={180} class="hero-accent">THINK.</TextReveal>
          </h1>
          <ScrollReveal delay={280} class="blog-hero-intro">
            <p>
              <span data-zh>我是朱彥勳，目前就讀國立陽明交通大學電控工程研究所碩士班。</span>
              <span data-en>I am Patrick Zhu, currently pursuing an M.S. at the Institute of Electrical and Control Engineering, National Yang Ming Chiao Tung University.</span>
            </p>
          </ScrollReveal>
          <ScrollReveal delay={380} class="blog-hero-links">
            <a href="#articles"><span data-zh>閱讀文章</span><span data-en>Read articles</span><span aria-hidden="true">↓</span></a>
            <SocialLinks compact />
          </ScrollReveal>
        </div>

        <figure class="blog-portrait">
          <img src={profile.portrait} alt={`${profile.name} ${profile.englishName} 個人形象照`} />
          <figcaption><span>MECHATRONICS × AI</span><span>TAIWAN · 2026</span></figcaption>
        </figure>
      </div>
    </section>

    <section id="articles" class="blog-index-section" aria-labelledby="article-index-title">
      <div class="cinematic-wrap">
        <header class="blog-index-heading">
          <p><span data-zh>文章</span><span data-en>WRITING</span></p>
          <h2 id="article-index-title">
            <TextReveal><span data-zh>最新文章</span><span data-en>Latest articles</span></TextReveal>
          </h2>
        </header>

        {posts.length ? (
          <>
            <div class="blog-toolbar">
              <label class="blog-search">
                <Icon name="search" size={18} />
                <input id="writingSearch" type="search" placeholder="搜尋文章或標籤" aria-label="搜尋文章" />
              </label>
              <div class="blog-filters" id="writingFilters">
                <button data-tag="all" aria-pressed="true">全部</button>
                {tags.map((tag) => <button data-tag={tag} aria-pressed="false">{tag}</button>)}
              </div>
            </div>
            <div class="article-card-grid" id="writingList">
              {posts.map((post, index) => (
                <ScrollReveal delay={Math.min(index, 5) * 70}>
                  <a
                    class:list={["article-card", `article-tone-${["lime", "blue", "coral", "white"][index % 4]}`]}
                    href={`/writing/${post.id}/`}
                    data-search={`${post.data.title} ${post.data.summary} ${post.data.tags.join(" ")}`.toLowerCase()}
                    data-tags={post.data.tags.join("|")}
                  >
                    <div class="article-card-cover">
                      {post.data.cover ? <img src={post.data.cover} alt="" /> : <strong>{post.data.tags[0] || "NOTES"}</strong>}
                      <span>{String(index + 1).padStart(2, "0")}</span>
                    </div>
                    <div class="article-card-body">
                      <div class="article-card-meta">
                        <time datetime={post.data.publishedAt.toISOString()}>{post.data.publishedAt.toLocaleDateString("zh-TW")}</time>
                        <span>{post.data.tags[0] || "NOTES"}</span>
                      </div>
                      <h3>{post.data.title}</h3>
                      <span class="article-card-arrow" aria-hidden="true">↗</span>
                    </div>
                  </a>
                </ScrollReveal>
              ))}
            </div>
            <p class="empty" id="writingNoResults">找不到符合條件的文章。</p>
          </>
        ) : (
          <div class="article-card-grid article-template-grid" aria-label="文章卡片版型預覽">
            {templatePosts.map((post, index) => (
              <ScrollReveal delay={index * 90}>
                <article class:list={["article-card", "article-template-card", `article-tone-${post.tone}`]} tabindex="0">
                  <div class="article-card-cover">
                    <strong>{post.category}</strong>
                    <span>{post.index}</span>
                  </div>
                  <div class="article-card-body">
                    <div class="article-card-meta">
                      <span><span data-zh>文章範本</span><span data-en>ARTICLE TEMPLATE</span></span>
                      <span>{post.category}</span>
                    </div>
                    <h3><span data-zh>{post.titleZh}</span><span data-en>{post.titleEn}</span></h3>
                    <span class="article-card-arrow" aria-hidden="true">↗</span>
                  </div>
                </article>
              </ScrollReveal>
            ))}
          </div>
        )}
      </div>
    </section>
  </main>

  {posts.length > 0 && <script is:inline>
    const search = document.querySelector("#writingSearch");
    const filters = document.querySelector("#writingFilters");
    const rows = Array.from(document.querySelectorAll(".article-card"));
    const empty = document.querySelector("#writingNoResults");
    let activeTag = "all";
    const render = () => {
      const term = search.value.trim().toLowerCase();
      let visible = 0;
      rows.forEach((row) => {
        const tagMatch = activeTag === "all" || row.dataset.tags.split("|").includes(activeTag);
        const show = tagMatch && (!term || row.dataset.search.includes(term));
        row.closest(".scroll-reveal").hidden = !show;
        if (show) visible += 1;
      });
      empty?.classList.toggle("is-visible", visible === 0);
    };
    search?.addEventListener("input", render);
    filters?.addEventListener("click", (event) => {
      const button = event.target.closest("[data-tag]");
      if (!button) return;
      activeTag = button.dataset.tag;
      filters.querySelectorAll("[data-tag]").forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
      render();
    });
  </script>}
</Base>
