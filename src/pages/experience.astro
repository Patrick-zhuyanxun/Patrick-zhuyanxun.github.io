---
import Base from "../layouts/Base.astro";
import Journey from "../components/Journey.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
import TextReveal from "../components/TextReveal.astro";
import { profile } from "../data/site";
---

<Base title={`經歷 | ${profile.name} ${profile.englishName}`} description="朱彥勳的學習、研究、教學與工程實作經歷。">
  <main id="main-content">
    <section class="wrap page-intro">
      <p class="section-label">EXPERIENCE</p>
      <h1><TextReveal><span data-zh>經歷</span><span data-en>Experience</span></TextReveal></h1>
      <ScrollReveal delay={120} class="page-intro-copy">
        <p><span data-zh>我的學歷、研究、實習與教學經歷。</span><span data-en>My education, research, internships and teaching experience.</span></p>
      </ScrollReveal>
    </section>
    <Journey />
  </main>
</Base>
