---
import { getCollection } from "astro:content";
import Base from "../layouts/Base.astro";
import Icon from "../components/Icon.astro";
import { profile } from "../data/site";

const posts = (await getCollection("writing", ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.valueOf() - a.data.publishedAt.valueOf());
const tags = [...new Set(posts.flatMap((post) => post.data.tags))].sort();
---

<Base title={`文章與觀點 | ${profile.name} ${profile.englishName}`} description="朱彥勳整理閱讀、觀看、技術與生活觀察後公開留下的文章與觀點。">
  <main id="main-content">
    <section class="wrap page-intro writing-intro">
      <p class="section-label">WRITING & IDEAS</p>
      <h1><span data-zh>把看過的事，<br />變成自己的理解。</span><span data-en>Turning what I encounter<br />into my own understanding.</span></h1>
      <p><span data-zh>技術、書籍、影片與生活觀察。這裡不追求即時更新，只收錄已經消化、願意公開留下的內容。</span><span data-en>Technology, books, videos and observations. This is not a real-time feed, only a home for ideas ready to be kept in public.</span></p>
    </section>

    <section class="section writing-archive">
      <div class="wrap">
        {posts.length ? (
          <>
            <div class="writing-toolbar">
              <label class="search-box"><Icon name="search" size={18} /><input id="writingSearch" type="search" placeholder="搜尋文章或標籤" aria-label="搜尋文章" /></label>
              <div class="filters" id="writingFilters"><button class="filter" data-tag="all" aria-pressed="true">全部</button>{tags.map((tag) => <button class="filter" data-tag={tag} aria-pressed="false">{tag}</button>)}</div>
            </div>
            <div class="writing-list" id="writingList">
              {posts.map((post) => (
                <a class="writing-row" href={`/writing/${post.id}/`} data-search={`${post.data.title} ${post.data.summary} ${post.data.tags.join(" ")}`.toLowerCase()} data-tags={post.data.tags.join("|")}>
                  <time datetime={post.data.publishedAt.toISOString()}>{post.data.publishedAt.toLocaleDateString("zh-TW")}</time>
                  <div><h2>{post.data.title}</h2><p>{post.data.summary}</p><div class="tag-list">{post.data.tags.map((tag) => <span class="tag">{tag}</span>)}</div></div>
                  <span aria-hidden="true">↗</span>
                </a>
              ))}
            </div>
            <p class="empty" id="writingNoResults">找不到符合條件的文章。</p>
          </>
        ) : (
          <div class="writing-empty large">
            <p class="empty-mark">01</p>
            <div>
              <strong><span data-zh>第一篇內容還在整理中。</span><span data-en>The first piece is still taking shape.</span></strong>
              <p><span data-zh>我會先在私人知識庫中閱讀、記錄與重寫；當內容真正成形後，才會發布在這裡。</span><span data-en>I read, take notes and rewrite in private first. When an idea is ready, it will be published here.</span></p>
            </div>
          </div>
        )}
      </div>
    </section>
  </main>
  {posts.length > 0 && <script is:inline>
    const search = document.querySelector("#writingSearch");
    const filters = document.querySelector("#writingFilters");
    const rows = Array.from(document.querySelectorAll(".writing-row"));
    const empty = document.querySelector("#writingNoResults");
    let activeTag = "all";
    const render = () => {
      const term = search.value.trim().toLowerCase();
      let visible = 0;
      rows.forEach((row) => {
        const tagMatch = activeTag === "all" || row.dataset.tags.split("|").includes(activeTag);
        const show = tagMatch && (!term || row.dataset.search.includes(term));
        row.hidden = !show;
        if (show) visible += 1;
      });
      empty?.classList.toggle("is-visible", visible === 0);
    };
    search?.addEventListener("input", render);
    filters?.addEventListener("click", (event) => {
      const button = event.target.closest("[data-tag]");
      if (!button) return;
      activeTag = button.dataset.tag;
      filters.querySelectorAll("[data-tag]").forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
      render();
    });
  </script>}
</Base>
