---
import Base from "../../layouts/Base.astro";
import Icon from "../../components/Icon.astro";
import ProjectCard from "../../components/ProjectCard.astro";
import ScrollReveal from "../../components/ScrollReveal.astro";
import TextReveal from "../../components/TextReveal.astro";
import { categories, projects } from "../../data/site";
import { projectCategoryLabels, projectTranslations } from "../../data/projectTranslations";
---

<Base title="專案總覽 | 朱彥勳 Patrick Zhu">
  <main id="main-content" class="projects-page">
    <section class="wrap archive-intro">
      <p class="eyebrow">PROJECT ARCHIVE</p>
      <h1><TextReveal><span data-zh>專案</span><span data-en>Projects</span></TextReveal></h1>
      <ScrollReveal delay={120} class="archive-intro-copy">
        <p><span data-zh>我做過機器人操作、6D 姿態估測、機器視覺、自主移動與機電整合專案。每個專案頁記錄我負責的部分、使用技術與成果。</span><span data-en>I have worked on robotic manipulation, 6D pose estimation, machine vision, autonomous mobility and mechatronics integration. Each project records my role, technologies and outcomes.</span></p>
      </ScrollReveal>
    </section>

    <section class="archive">
      <div class="wrap">
        <div class="archive-toolbar">
          <label class="search-box"><Icon name="search" size={20} /><input id="projectSearch" type="search" placeholder="搜尋專案、技術或關鍵字" data-placeholder-zh="搜尋專案、技術或關鍵字" data-placeholder-en="Search projects, technologies or keywords" aria-label="搜尋專案" /></label>
          <div class="filters" id="filterRow" aria-label="專案分類">
            <button class="filter" type="button" data-filter="all" aria-pressed="true"><span data-zh>全部專案</span><span data-en>All projects</span></button>
            {categories.map((category) => {
              const label = projectCategoryLabels[category.id] || { zh: category.label, en: category.label };
              return <button class="filter" type="button" data-filter={category.id} aria-pressed="false"><span data-zh>{label.zh}</span><span data-en>{label.en}</span></button>;
            })}
          </div>
        </div>
        <div class="result-bar">
          <span><span data-zh id="resultCountZh">顯示 9 / {projects.length} 個專案</span><span data-en id="resultCountEn">Showing 9 / {projects.length} projects</span></span>
          <span><span data-zh>點選卡片查看專案細節</span><span data-en>Select a card to view project details</span></span>
        </div>
        <div class="project-grid" id="projectGrid">
          {projects.map((project, index) => {
            const translation = projectTranslations[project.id];
            return <div class:list={["project-listing", { "is-hidden": index >= 9 }]} data-category={[project.category, ...(project.groups || [])].join(" ")} data-search={[project.title, project.shortTitle, project.organization, project.summary, translation?.title, translation?.organization, translation?.summary, ...(project.tags || [])].join(" ").toLowerCase()}><ProjectCard project={project} featured={index < 2} /></div>;
          })}
        </div>
        <div class="empty" id="emptyState"><span data-zh>找不到符合目前條件的專案。</span><span data-en>No projects match these filters.</span></div>
        <button class="load-more is-visible" id="loadMore" type="button"><span data-zh id="loadMoreZh">顯示更多專案</span><span data-en id="loadMoreEn">Show more projects</span></button>
      </div>
    </section>
  </main>
  <script is:inline>
    const pageSize = 9;
    let visibleLimit = pageSize;
    let activeFilter = "all";
    const cards = Array.from(document.querySelectorAll(".project-listing"));
    const search = document.querySelector("#projectSearch");
    const filterRow = document.querySelector("#filterRow");
    const resultCountZh = document.querySelector("#resultCountZh");
    const resultCountEn = document.querySelector("#resultCountEn");
    const emptyState = document.querySelector("#emptyState");
    const loadMore = document.querySelector("#loadMore");

    const renderProjects = () => {
      const term = search.value.trim().toLowerCase();
      const matched = cards.filter((card) => {
        const matchesCategory = activeFilter === "all" || card.dataset.category.split(" ").includes(activeFilter);
        return matchesCategory && (!term || card.dataset.search.includes(term));
      });
      cards.forEach((card) => card.classList.add("is-hidden"));
      matched.slice(0, visibleLimit).forEach((card) => card.classList.remove("is-hidden"));
      resultCountZh.textContent = matched.length ? `顯示 ${Math.min(visibleLimit, matched.length)} / ${matched.length} 個專案` : "沒有符合的專案";
      resultCountEn.textContent = matched.length ? `Showing ${Math.min(visibleLimit, matched.length)} / ${matched.length} projects` : "No matching projects";
      emptyState.classList.toggle("is-visible", matched.length === 0);
      loadMore.classList.toggle("is-visible", matched.length > visibleLimit);
      document.querySelector("#loadMoreZh").textContent = `顯示更多專案（尚有 ${Math.max(matched.length - visibleLimit, 0)} 項）`;
      document.querySelector("#loadMoreEn").textContent = `Show more projects (${Math.max(matched.length - visibleLimit, 0)} remaining)`;
    };

    filterRow.addEventListener("click", (event) => {
      const button = event.target.closest("[data-filter]");
      if (!button) return;
      activeFilter = button.dataset.filter;
      visibleLimit = pageSize;
      filterRow.querySelectorAll("[data-filter]").forEach((item) => item.setAttribute("aria-pressed", String(item === button)));
      renderProjects();
    });
    search.addEventListener("input", () => { visibleLimit = pageSize; renderProjects(); });
    loadMore.addEventListener("click", () => { visibleLimit += pageSize; renderProjects(); });
    renderProjects();
  </script>
</Base>
