---
import "../styles/global.css";
import SocialLinks from "../components/SocialLinks.astro";
import { profile } from "../data/site";

interface Props {
  title?: string;
  description?: string;
  image?: string;
  article?: boolean;
  bodyClass?: string;
  homeNavigation?: boolean;
  themeColor?: string;
}

const {
  title = `${profile.name} ${profile.englishName}`,
  description = "朱彥勳的個人網站，整理文章、觀點、工程專案與經歷。",
  image = profile.portrait,
  article = false,
  bodyClass = "",
  homeNavigation = false,
  themeColor = "#f7eee6"
} = Astro.props;
const base = import.meta.env.BASE_URL;
const href = (path: string) => `${base}${path}`;
const currentPath = Astro.url.pathname;
const isCurrent = (path: string) => path === "/"
  ? currentPath === "/"
  : currentPath.startsWith(path);
const isWriting = currentPath === "/" || currentPath.startsWith("/writing/");
const canonical = new URL(Astro.url.pathname, Astro.site);
const socialImage = new URL(image, Astro.site);
const structuredData = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: `${profile.name} ${profile.englishName}`,
  alternateName: profile.englishName,
  url: profile.site,
  image: socialImage.toString(),
  sameAs: [profile.github, profile.linkedin],
  email: `mailto:${profile.email}`
};
---

<!doctype html>
<html lang="zh-Hant-TW">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="theme-color" content={themeColor} />
    <meta property="og:type" content={article ? "article" : "website"} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical.toString()} />
    <meta property="og:image" content={socialImage.toString()} />
    <meta property="og:locale" content="zh_TW" />
    <meta name="twitter:card" content="summary_large_image" />
    <link rel="canonical" href={canonical} />
    <link rel="sitemap" href="/sitemap-index.xml" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <script type="application/ld+json" set:html={JSON.stringify(structuredData)} />
    <script is:inline>document.documentElement.dataset.motionReady = "true";</script>
  </head>
  <body class={bodyClass}>
    <a class="skip-link" href="#main-content">跳至主要內容</a>
    <header class="site-header">
      <nav class="wrap site-nav" aria-label="主要導覽">
        <a class="brand" href={href("")}>{profile.name} <small>{profile.englishName}</small></a>
        {homeNavigation ? (
          <div class="nav-links home-nav-links">
            <a href="#top" data-nav-section="top"><span data-zh>首頁</span><span data-en>Home</span></a>
            <a href="#featured" data-nav-section="featured"><span data-zh>代表專案</span><span data-en>Featured</span></a>
            <a href="#all-projects" data-nav-section="all-projects"><span data-zh>全部專案</span><span data-en>Projects</span></a>
            <a href="#experience" data-nav-section="experience"><span data-zh>經歷</span><span data-en>Experience</span></a>
            <a href="#about" data-nav-section="about"><span data-zh>關於</span><span data-en>About</span></a>
          </div>
        ) : (
          <div class="nav-links">
            <a class:list={{ "is-active": isWriting }} href={href("")}><span data-zh>文章</span><span data-en>Writing</span></a>
            <a class:list={{ "is-active": isCurrent("/projects/") }} href={href("projects/")}><span data-zh>專案</span><span data-en>Projects</span></a>
            <a class:list={{ "is-active": isCurrent("/experience/") }} href={href("experience/")}><span data-zh>經歷</span><span data-en>Experience</span></a>
            <a class:list={{ "is-active": isCurrent("/about/") }} href={href("about/")}><span data-zh>關於</span><span data-en>About</span></a>
            <a class:list={{ "is-active": isCurrent("/resume/") }} href={href("resume/")}><span data-zh>履歷</span><span data-en>Resume</span></a>
          </div>
        )}
        <button class="lang-toggle" type="button" aria-label="切換中文與英文">中 / EN</button>
      </nav>
      {!homeNavigation && (
        <nav class="mobile-page-nav" aria-label="手機版主要導覽">
          <a class:list={{ "is-active": isWriting }} href={href("")}><span data-zh>文章</span><span data-en>Writing</span></a>
          <a class:list={{ "is-active": isCurrent("/projects/") }} href={href("projects/")}><span data-zh>專案</span><span data-en>Projects</span></a>
          <a class:list={{ "is-active": isCurrent("/experience/") }} href={href("experience/")}><span data-zh>經歷</span><span data-en>Experience</span></a>
          <a class:list={{ "is-active": isCurrent("/about/") }} href={href("about/")}><span data-zh>關於</span><span data-en>About</span></a>
          <a class:list={{ "is-active": isCurrent("/resume/") }} href={href("resume/")}><span data-zh>履歷</span><span data-en>Resume</span></a>
        </nav>
      )}
    </header>
    <slot />
    <footer class="site-footer">
      <div class="wrap footer-grid">
        <div>
          <p class="footer-label"><span data-zh>保持好奇，持續整理。</span><span data-en>Stay curious. Keep making sense of things.</span></p>
          <h2>{profile.name} <span>{profile.englishName}</span></h2>
        </div>
        <SocialLinks compact />
        <p class="footer-meta">© {new Date().getFullYear()} · TAIWAN</p>
      </div>
    </footer>
    <script is:inline>
      const toggle = document.querySelector(".lang-toggle");
      const savedLanguage = localStorage.getItem("patrick-site-language");
      const setLanguage = (language) => {
        const english = language === "en";
        document.body.classList.toggle("en", english);
        document.documentElement.lang = english ? "en" : "zh-Hant-TW";
        toggle?.setAttribute("aria-label", english ? "Switch to Traditional Chinese" : "切換至英文");
        document.querySelectorAll("[data-placeholder-en]").forEach((field) => {
          field.setAttribute("placeholder", english ? field.dataset.placeholderEn : field.dataset.placeholderZh);
        });
      };
      setLanguage(savedLanguage === "en" ? "en" : "zh");
      toggle?.addEventListener("click", () => {
        const next = document.body.classList.contains("en") ? "zh" : "en";
        localStorage.setItem("patrick-site-language", next);
        setLanguage(next);
      });
    </script>
    <script>
      const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

      const initializeReveals = (
        selector: string,
        rootMargin: string,
        threshold: number
      ) => {
        const targets = document.querySelectorAll<HTMLElement>(
          `${selector}:not([data-reveal-ready])`
        );

        if (reduceMotion || !("IntersectionObserver" in window)) {
          targets.forEach((target) => target.classList.add("is-visible"));
          return;
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach((entry) => {
            const target = entry.target as HTMLElement;
            if (entry.isIntersecting) {
              target.classList.add("is-visible");
              if (target.dataset.triggerOnce !== "false") observer.unobserve(target);
            } else if (target.dataset.triggerOnce === "false") {
              target.classList.remove("is-visible");
            }
          });
        }, { rootMargin, threshold });

        targets.forEach((target) => {
          target.dataset.revealReady = "true";
          observer.observe(target);
        });
      };

      initializeReveals("[data-text-reveal]", "0px 0px -8% 0px", 0.1);
      initializeReveals("[data-scroll-reveal]", "0px 0px -12% 0px", 0.12);
    </script>
  </body>
</html>
