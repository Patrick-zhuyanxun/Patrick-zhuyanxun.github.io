#!/usr/bin/env sh
set -eu

if command -v node >/dev/null 2>&1; then
  node_bin="$(command -v node)"
elif [ -n "${USERPROFILE:-}" ] && [ -x "$USERPROFILE/.cache/codex-runtimes/codex-primary-runtime/dependencies/node/bin/node.exe" ]; then
  node_bin="$USERPROFILE/.cache/codex-runtimes/codex-primary-runtime/dependencies/node/bin/node.exe"
else
  echo "Node.js is required to sync career data before committing."
  exit 1
fi

"$node_bin" scripts/sync-career-data.mjs
git add -- src/data/projects.json public/images/projects public/files/patrick-zhu-resume-zh.pdf
